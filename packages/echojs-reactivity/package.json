    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "alien-signals": "^3.1.2"
  },
  "devDependencies": {
    "@echojs/oxc-config": "workspace:*",
    "oxlint": "^1.60.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  }
}
